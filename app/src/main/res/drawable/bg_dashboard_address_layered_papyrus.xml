<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Layer 3: Bottom shadow layer -->
    <item android:top="6dp" android:left="4dp">
        <shape android:shape="rectangle">
            <corners android:radius="14dp" />
            <solid android:color="#0D000000" />
        </shape>
    </item>

    <!-- Layer 2: Middle stacked paper layer -->
    <item android:top="3dp" android:left="2dp" android:right="2dp" android:bottom="3dp">
        <shape android:shape="rectangle">
            <corners android:radius="14dp" />
            <solid android:color="@color/off_white_dark" />
            <stroke android:width="1dp" android:color="@color/off_white_grayish" />
        </shape>
    </item>

    <!-- Layer 1: Top main papyrus layer -->
    <item android:bottom="6dp" android:right="4dp">
        <shape android:shape="rectangle">
            <corners android:radius="14dp" />
            <solid android:color="@color/off_white_primary" />
            <stroke android:width="1.5dp" android:color="@color/emerald_alpha_20" />
        </shape>
    </item>

    <!-- Accent: The 'folded' edge highlight (Ivory-Emerald) -->
    <item android:bottom="6dp" android:right="4dp" android:left="0dp" android:top="0dp">
        <shape android:shape="rectangle">
            <corners android:radius="14dp" />
            <gradient
                android:startColor="#10007F5F"
                android:endColor="@android:color/transparent"
                android:angle="135"
                android:type="linear" />
        </shape>
    </item>
</layer-list>
