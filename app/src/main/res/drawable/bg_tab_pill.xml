<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Outer Shadow -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/clay_dark_shadow" />
            <corners android:radius="100dp" />
        </shape>
    </item>

    <!-- Main Pill Body -->
    <item android:bottom="2dp" android:left="1dp" android:right="1dp" android:top="1dp">
        <shape android:shape="rectangle">
            <solid android:color="@color/tab_switcher_pill" />
            <corners android:radius="100dp" />
        </shape>
    </item>

    <!-- Top Highlight -->
    <item android:bottom="4dp" android:left="2dp" android:right="2dp" android:top="2dp">
        <shape android:shape="rectangle">
            <solid android:color="@color/clay_light_shadow" />
            <corners android:radius="100dp" />
        </shape>
    </item>
</layer-list>
