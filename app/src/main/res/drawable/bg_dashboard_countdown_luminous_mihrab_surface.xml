<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Concept M: The Luminous Mihrab Surface
         A deeply inset architectural niche with a sharp pointed arch (Mihrab). -->
    
    <!-- Outer Inset Border/Shadow -->
    <item>
        <shape android:shape="rectangle">
            <corners 
                android:topLeftRadius="80dp"
                android:topRightRadius="80dp"
                android:bottomLeftRadius="20dp"
                android:bottomRightRadius="20dp" />
            <solid android:color="#0D000000" />
        </shape>
    </item>

    <!-- Deep Emerald Base (The Inset Depth) -->
    <item android:top="2dp" android:left="2dp" android:right="2dp" android:bottom="4dp">
        <shape android:shape="rectangle">
            <corners 
                android:topLeftRadius="78dp"
                android:topRightRadius="78dp"
                android:bottomLeftRadius="18dp"
                android:bottomRightRadius="18dp" />
            <solid android:color="@color/emerald_dark" />
            <stroke android:width="1dp" android:color="#30FFFFFF" /> <!-- Inner glow stroke -->
        </shape>
    </item>

    <!-- Shimmering Atmosphere (Dark base gradient) -->
    <item android:top="2dp" android:left="2dp" android:right="2dp" android:bottom="4dp">
        <shape android:shape="rectangle">
            <corners 
                android:topLeftRadius="78dp"
                android:topRightRadius="78dp"
                android:bottomLeftRadius="18dp"
                android:bottomRightRadius="18dp" />
            <gradient
                android:startColor="#00000000"
                android:centerColor="#10FFFFFF"
                android:endColor="#00000000"
                android:angle="0"
                android:type="linear"/>
        </shape>
    </item>

</layer-list>
