<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:isScrollContainer="true"
    android:background="@color/off_white_primary"
    tools:context=".LoginActivity">

    <LinearLayout
        android:id="@+id/login_root"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal">

        <!-- Madina Logo -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/logo_container"
            android:layout_width="0dp"
            android:layout_height="0dp"
            app:cardBackgroundColor="@android:color/transparent"
            app:cardCornerRadius="0dp"
            app:cardElevation="0dp">

            <ImageView
                android:id="@+id/img_logo"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:src="@drawable/madina"
                android:scaleType="fitCenter"
                android:contentDescription="@string/cd_masjid_logo" />
        </com.google.android.material.card.MaterialCardView>

        <!-- Title -->
        <LinearLayout
            android:id="@+id/layout_login_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center">

            <TextView
                android:id="@+id/txt_title_imam"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/login_title_imam"
                android:textColor="@color/emerald_primary"
                android:fontFamily="@font/saleha_font" />

            <TextView
                android:id="@+id/txt_title_login"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/login_title_login"
                android:textColor="@color/emerald_primary"
                android:fontFamily="@font/saleha_font" />
        </LinearLayout>

        <!-- Main Login Card (Claymorphic) -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/login_card"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@android:color/transparent"
            app:cardCornerRadius="0dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:id="@+id/login_form"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center_horizontal">

                <!-- Full Name Input -->
                <EditText
                    android:id="@+id/edt_full_name"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/full_name_hint"
                    android:fontFamily="@font/janna_it_bold_font"
                    android:inputType="textPersonName"
                    android:textColor="@color/emerald_primary"
                    android:textColorHint="@color/input_placeholder"
                    android:textCursorDrawable="@null"
                    android:importantForAutofill="no"
                    android:background="@android:color/transparent" />

                <!-- Password Area Container -->
                <RelativeLayout
                    android:id="@+id/password_container"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">
                    
                    <EditText
                        android:id="@+id/edt_password"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="@string/password_hint"
                        android:fontFamily="@font/janna_it_bold_font"
                        android:inputType="textPassword"
                        android:textColor="@color/emerald_primary"
                        android:textColorHint="@color/input_placeholder"
                        android:textCursorDrawable="@null"
                        android:importantForAutofill="no"
                        android:background="@android:color/transparent" />

                    <ImageView
                        android:id="@+id/btn_toggle_password"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:src="@drawable/ic_eye_hidden"
                        android:contentDescription="@string/cd_toggle_password" />
                </RelativeLayout>

                <!-- Masjid Dropdown Selection -->
                <TextView
                    android:id="@+id/dropdown_masjid"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/select_masjid"
                    android:fontFamily="@font/janna_it_bold_font"
                    android:textColor="@color/emerald_primary"
                    android:gravity="center_vertical"
                    android:background="@android:color/transparent"
                    app:drawableEndCompat="@android:drawable/arrow_down_float" />

                <!-- Detail Tip Instruction -->
                <TextView
                    android:id="@+id/txt_masjid_hint"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/masjid_details_hint"
                    android:textColor="@color/text_secondary"
                    android:fontFamily="@font/janna_it_bold_font"
                    android:gravity="center"
                    android:alpha="0.8" />

                <!-- Error Message Display -->
                <TextView
                    android:id="@+id/txt_error_message"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/invalid_credentials"
                    android:textColor="@color/error_red"
                    android:fontFamily="@font/janna_it_bold_font"
                    android:visibility="gone" />

                <!-- Submit Button Area -->
                <FrameLayout
                    android:id="@+id/btn_submit_container"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_submit"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/submit"
                        android:textAllCaps="false"
                        android:fontFamily="@font/saleha_font"
                        app:backgroundTint="@color/emerald_primary" />

                    <ProgressBar
                        android:id="@+id/progress_login"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:visibility="gone"
                        android:indeterminateTint="@color/off_white_primary" />
                </FrameLayout>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>

</ScrollView>
