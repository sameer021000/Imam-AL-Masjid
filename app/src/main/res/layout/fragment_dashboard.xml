<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/dashboard_root_scroll"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/transparent"
    android:scrollbars="none"
    android:clipChildren="false"
    android:clipToPadding="false">


    <LinearLayout
        android:id="@+id/dashboard_content_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:clipChildren="false"
        android:clipToPadding="false">


        <!-- 1. Top Accented Section (Header + Dates) -->
        <LinearLayout
            android:id="@+id/layout_top_accent_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:background="@color/dashboard_top_accent_bg"
            android:paddingBottom="5dp"
            android:clipChildren="false"
            android:clipToPadding="false">

            <!-- 1. Header Section (Horizon V2) -->
            <FrameLayout
                android:id="@+id/dashboard_header_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal">

                <!-- Horizon Gradient Backdrop -->
                <View
                    android:id="@+id/header_horizon_backdrop"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/header_horizon_gradient" />

                <LinearLayout
                    android:id="@+id/dashboard_header_section"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:paddingBottom="12dp">

                    <TextView
                        android:id="@+id/txt_dashboard_masjid_name"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/dashboard_masjid_name"
                        android:textColor="@color/emerald_primary"
                        android:fontFamily="@font/saleha_font" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginTop="2dp">

                        <TextView
                            android:id="@+id/txt_dashboard_masjid_address"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/address_alamgeer"
                            android:textColor="@color/off_white_primary"
                            android:fontFamily="@font/chillax_medium_font"
                            android:gravity="center"
                            android:alpha="0.8" />

                        <ImageView
                            android:id="@+id/img_header_location"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:layout_marginStart="8dp"
                            android:src="@drawable/ic_location_pin"
                            app:tint="@color/off_white_primary"
                            android:alpha="0.9"
                            android:background="?attr/selectableItemBackgroundBorderless"
                            android:contentDescription="@string/cd_masjid_location" />
                    </LinearLayout>
                </LinearLayout>
            </FrameLayout>

            <!-- 1.5 Date Section (Celestial Axis V1) -->
            <LinearLayout
                android:id="@+id/container_dashboard_dates"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="4dp">

                <FrameLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:clipChildren="true">
                    <TextView
                        android:id="@+id/txt_dashboard_hijri_date"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/dashboard_hijri_date"
                        android:textColor="@color/emerald_dark"
                        android:background="@drawable/bg_lunar_chip"
                        android:paddingHorizontal="16dp"
                        android:paddingVertical="4dp"
                        android:fontFamily="@font/janna_it_bold_font" />
                </FrameLayout>

                <FrameLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="8dp">
                    
                    <View
                        android:id="@+id/divider_dates"
                        android:layout_width="1.5dp"
                        android:layout_height="24dp"
                        android:layout_gravity="center"
                        android:background="@color/celestial_gold"
                        android:alpha="0.8" />
                    
                    <!-- Axis Glow Dots -->
                    <View
                        android:id="@+id/dot_axis_top"
                        android:layout_width="4dp"
                        android:layout_height="4dp"
                        android:layout_gravity="top|center_horizontal"
                        android:background="@drawable/ic_location_pin"
                        android:backgroundTint="@color/celestial_gold" />

                    <View
                        android:id="@+id/dot_axis_bottom"
                        android:layout_width="4dp"
                        android:layout_height="4dp"
                        android:layout_gravity="bottom|center_horizontal"
                        android:background="@drawable/ic_location_pin"
                        android:backgroundTint="@color/celestial_gold" />
                </FrameLayout>

                <FrameLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:clipChildren="true">
                    <TextView
                        android:id="@+id/txt_dashboard_current_date"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/dashboard_current_date_placeholder"
                        android:textColor="@color/emerald_dark"
                        android:background="@drawable/bg_solar_chip"
                        android:paddingHorizontal="16dp"
                        android:paddingVertical="4dp"
                        android:fontFamily="@font/janna_it_bold_font" />
                </FrameLayout>
            </LinearLayout>
        </LinearLayout>

        <!-- 2. Announcements Panel (Immediate Visibility) -->
        <LinearLayout
            android:id="@+id/panel_announcements"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone"
            android:paddingHorizontal="24dp"
            android:paddingVertical="8dp"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="8dp">

            <TextView
                android:id="@+id/txt_announcements_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/dashboard_announcements_label"
                android:textColor="@color/emerald_primary"
                android:textSize="12sp"
                android:fontFamily="@font/janna_it_bold_font" />

            <TextView
                android:id="@+id/txt_announcement_content"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/dashboard_announcement_text"
                android:textColor="@color/emerald_dark"
                android:textSize="13sp"
                android:fontFamily="@font/chillax_medium_font" />
        </LinearLayout>

        <!-- 3. Dynamic Slide Bar (Tab Switcher) -->
        <FrameLayout
            android:id="@+id/layout_tab_switcher"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginHorizontal="24dp"
            android:layout_marginBottom="12dp"
            android:background="@drawable/bg_tab_track">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tab_masjid_times"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="Masjid Times"
                    android:textColor="@color/tab_text_active"
                    android:fontFamily="@font/janna_it_bold_font"
                    android:clickable="true"
                    android:focusable="true" />

                <TextView
                    android:id="@+id/tab_waqt_details"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="Waqt Details"
                    android:textColor="@color/tab_text_inactive"
                    android:fontFamily="@font/janna_it_bold_font"
                    android:clickable="true"
                    android:focusable="true" />
            </LinearLayout>
        </FrameLayout>


        <!-- 4. Main Panel Content Area -->
        <FrameLayout
            android:id="@+id/layout_panels_mount"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:clipChildren="false"
            android:clipToPadding="false">

            <LinearLayout
                android:id="@+id/panel_masjid_times"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="visible">

                <!-- Prayer Timings Pillar -->
                <LinearLayout
                    android:id="@+id/card_prayer_timings"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginTop="5dp"
                    android:paddingHorizontal="8dp"
                    android:clipToPadding="false"
                    android:clipChildren="false">
                    <include layout="@layout/item_prayer_timing_row" android:id="@+id/row_fajr" />
                    <include layout="@layout/item_prayer_timing_row" android:id="@+id/row_dhuhr" />
                    <include layout="@layout/item_prayer_timing_row" android:id="@+id/row_asr" />
                    <include layout="@layout/item_prayer_timing_row" android:id="@+id/row_maghrib" />
                    <include layout="@layout/item_prayer_timing_row" android:id="@+id/row_isha" />
                </LinearLayout>
            </LinearLayout>

            <!-- PANEL B: Waqt Details -->
            <LinearLayout
                android:id="@+id/panel_waqt_details"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone"
                android:paddingHorizontal="0dp">

                <!-- Address & Edit Section (Iteration 2: Concept D: Layered Papyrus) -->
                <FrameLayout
                    android:id="@+id/container_waqt_address"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:clipChildren="false"
                    android:clipToPadding="false">

                    <LinearLayout
                        android:id="@+id/layout_address_papyrus_surface"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingVertical="12dp"
                        android:background="@drawable/bg_dashboard_address_layered_papyrus">

                        <ImageView
                            android:id="@+id/img_location_pin"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:layout_marginStart="14dp"
                            android:src="@android:drawable/ic_menu_mylocation"
                            app:tint="@color/emerald_primary"
                            android:contentDescription="@string/cd_my_location" />

                        <TextView
                            android:id="@+id/txt_device_address"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="10dp"
                            android:layout_marginEnd="40dp"
                            android:text="@string/dashboard_detecting_location"
                            android:textColor="@color/emerald_dark"
                            android:textSize="13sp"
                            android:fontFamily="@font/chillax_medium_font"
                            android:maxLines="2"
                            android:ellipsize="end" />
                    </LinearLayout>

                    <!-- Convex Pill Button in the Top-Right Corner -->
                    <TextView
                        android:id="@+id/btn_edit_location"
                        android:layout_width="48dp"
                        android:layout_height="28dp"
                        android:layout_gravity="top|end"
                        android:layout_marginTop="2dp"
                        android:layout_marginEnd="2dp"
                        android:text="EDIT"
                        android:gravity="center"
                        android:textSize="10sp"
                        android:textColor="@color/emerald_primary"
                        android:fontFamily="@font/janna_it_bold_font"
                        android:clickable="true"
                        android:focusable="true" />
                </FrameLayout>

                <!-- Sacred Chronos Dial v4 -->
                <com.example.imam_al_masjid.ChronosDialView
                    android:id="@+id/view_chronos_dial"
                    android:layout_width="match_parent"
                    android:layout_height="320dp"
                    android:layout_marginTop="4dp"
                    android:layout_gravity="center"
                    android:clickable="true"
                    android:focusable="true" />

            </LinearLayout>

        </FrameLayout>

        <!-- Spacer to swallow extra space from fillViewport="true" -->
        <View
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

    </LinearLayout>
</ScrollView>
