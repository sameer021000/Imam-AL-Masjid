<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/off_white_primary"
    tools:context=".SplashActivity">

    <!-- Top Guideline (at 20% of the screen) -->
    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guideline_top"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_percent="0.25" />

    <!-- Logo / Madina Image Container (Dynamic Scaling in Java) -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/logo_container"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:cardBackgroundColor="@android:color/transparent"
        app:cardCornerRadius="0dp"
        app:cardElevation="0dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/guideline_top">

        <ImageView
            android:id="@+id/img_logo"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:src="@drawable/madina"
            android:scaleType="fitCenter"
            android:contentDescription="@string/app_name" />
    </com.google.android.material.card.MaterialCardView>

    <!-- App Name (Animated from bottom) -->
    <TextView
        android:id="@+id/txt_app_name"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/app_name"
        android:textColor="@color/emerald_primary"
        android:gravity="center"
        android:fontFamily="@font/saleha_font"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/logo_container" />

    <TextView
        android:id="@+id/txt_arabic_name"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/arabic_name"
        android:textColor="@color/emerald_dark"
        android:gravity="center"
        android:fontFamily="@font/janna_it_bold_font"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/txt_app_name" />

</androidx.constraintlayout.widget.ConstraintLayout>
