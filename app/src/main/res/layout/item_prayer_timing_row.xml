<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/prayer_row_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:clipChildren="false"
        android:clipToPadding="false">

        <!-- Celestial Orbit Dial (Left) -->
        <com.example.imam_al_masjid.CelestialOrbitView
            android:id="@+id/view_celestial_orbit"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true" />

        <!-- Waqt Name (Next to Dial) -->
        <TextView
            android:id="@+id/txt_prayer_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_toEndOf="@id/view_celestial_orbit"
            android:layout_toStartOf="@id/layout_waqt_text_group"
            android:layout_centerVertical="true"
            android:text="@string/placeholder_waqt_name"
            android:textColor="@color/emerald_primary"
            android:fontFamily="@font/janna_it_bold_font"
            android:letterSpacing="0.05"
            android:maxLines="1"
            android:ellipsize="end" />

        <!-- Vertical Timing Stack (Center-Right) -->
        <LinearLayout
            android:id="@+id/layout_waqt_text_group"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_toStartOf="@id/container_speaker_toggle"
            android:layout_centerVertical="true"
            android:orientation="vertical"
            android:gravity="end">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">
                <TextView
                    android:id="@+id/lbl_azan"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/label_azan"
                    android:textColor="@color/text_secondary"
                    android:alpha="0.8"
                    android:fontFamily="@font/chillax_medium_font" />
                <TextView
                    android:id="@+id/txt_azan_time"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/placeholder_waqt_time"
                    android:textColor="@color/text_secondary"
                    android:fontFamily="@font/chillax_medium_font" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">
                <TextView
                    android:id="@+id/lbl_jamat"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/label_jamat"
                    android:textColor="@color/text_secondary"
                    android:alpha="0.8"
                    android:fontFamily="@font/chillax_medium_font" />
                <TextView
                    android:id="@+id/txt_jamat_time"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/placeholder_waqt_time"
                    android:textColor="@color/emerald_primary"
                    android:fontFamily="@font/janna_it_bold_font" />
            </LinearLayout>
        </LinearLayout>

        <!-- Speaker Toggle (Far Right - Inset Circle) -->
        <FrameLayout
            android:id="@+id/container_speaker_toggle"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true">
            
            <View
                android:id="@+id/view_speaker_inset_bg"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:alpha="0.3" />

            <ImageView
                android:id="@+id/img_azan_sound_toggle"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:src="@drawable/ic_settings_sound_on"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/cd_toggle_azan_sound" />
        </FrameLayout>

        <!-- Hidden Views (Maintain Backend Integrity) -->
        <TextView android:id="@+id/txt_start_time" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
        <TextView android:id="@+id/txt_end_time" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />

    </RelativeLayout>
