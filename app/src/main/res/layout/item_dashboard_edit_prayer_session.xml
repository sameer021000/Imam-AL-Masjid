<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/prayer_card_root"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:clipChildren="false"
    android:clipToPadding="false">

    <RelativeLayout
        android:id="@+id/layout_header_group"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:clipChildren="false"
        android:clipToPadding="false">

        <com.example.imam_al_masjid.CelestialOrbitView
            android:id="@+id/view_celestial_orbit"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true" />

        <TextView
            android:id="@+id/text_prayer_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerVertical="true"
            android:layout_toEndOf="@id/view_celestial_orbit"
            android:layout_toStartOf="@id/layout_contextual_action"
            android:letterSpacing="0.05"
            android:text="@string/placeholder_waqt_name"
            android:fontFamily="@font/janna_it_bold_font"
            android:textColor="@color/emerald_primary" />

        <LinearLayout
            android:id="@+id/layout_contextual_action"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:background="@drawable/bg_tab_track"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/img_contextual_icon"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/ic_settings_backup"
                app:tint="@color/text_secondary"
                android:contentDescription="@string/label_copy_yesterday"
                xmlns:app="http://schemas.android.com/apk/res-auto" />

            <TextView
                android:id="@+id/text_contextual_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/label_copy_yesterday"
                android:textColor="@color/text_secondary"
                android:fontFamily="@font/chillax_medium_font" />
        </LinearLayout>
    </RelativeLayout>

    <LinearLayout
        android:id="@+id/layout_edit_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:baselineAligned="false">

        <!-- Azan Edit Box -->
        <LinearLayout
            android:id="@+id/layout_edit_azan"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true">

            <TextView
                android:id="@+id/lbl_edit_azan"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/label_azan_plain"
                android:textColor="@color/text_secondary"
                android:fontFamily="@font/chillax_medium_font" />

            <TextView
                android:id="@+id/text_azan_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/placeholder_waqt_time"
                android:textColor="@color/emerald_primary"
                android:fontFamily="@font/janna_it_bold_font" />
        </LinearLayout>

        <View
            android:id="@+id/edit_divider"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_gravity="center_vertical"
            android:background="@color/emerald_alpha_20" />

        <!-- Jamat Edit Box -->
        <LinearLayout
            android:id="@+id/layout_edit_jamat"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true">

            <TextView
                android:id="@+id/lbl_edit_jamat"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/label_jamat_plain"
                android:textColor="@color/text_secondary"
                android:fontFamily="@font/chillax_medium_font" />

            <TextView
                android:id="@+id/text_jamat_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/placeholder_waqt_time"
                android:textColor="@color/emerald_primary"
                android:fontFamily="@font/janna_it_bold_font" />
        </LinearLayout>
    </LinearLayout>

    <TextView
        android:id="@+id/btn_submit_prayer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/label_submit_prayer"
        android:textColor="@color/off_white_primary"
        android:fontFamily="@font/janna_it_bold_font"
        android:gravity="center"
        android:letterSpacing="0.1"
        android:clickable="true"
        android:focusable="true"/>
</LinearLayout>
